# ── Common Config ─────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Backend Configuration ──────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ── Google OAuth Configuration ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# On Replit/Render, this must be the FULL PUBLIC URL of the backend endpoint
# Example: https://backend-repl.user.repl.co/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# The final URL to redirect the user to after a successful login
# Example: https://frontend-repl.user.repl.co
FRONTEND_URL=http://localhost:3000

# ── Frontend Configuration (Next.js) ──────────────────────────────────────────
# Used by Next.js to proxy requests to the backend
BACKEND_URL=http://localhost:8000

# ── Mail Configuration (Optional) ─────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
